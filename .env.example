# =============================================================================
# AII Smart Paper Maker — environment variables
# =============================================================================
# Copy this file to `.env` and fill in real values. NEVER commit `.env`.
# (`.gitignore` already ignores `.env` and `.env.*`.)
#
# python-dotenv loads `.env` automatically at startup, so you do NOT need to
# export these variables into your shell manually.
# =============================================================================


# -----------------------------------------------------------------------------
# AI provider keys — set AT LEAST ONE of the two below.
# -----------------------------------------------------------------------------
# Provider priority is fixed in code: if ANTHROPIC_API_KEY is set, Claude is
# used and GEMINI_API_KEY is ignored. Otherwise Gemini is used. If neither is
# set, question/syllabus generation fails at request time (the rest of the app
# still runs).

# Google Gemini — FREE, no credit card required. Recommended for testing.
# Get a key at https://aistudio.google.com  ("Get API key").
GEMINI_API_KEY=your-gemini-api-key-here

# Anthropic Claude — paid, higher quality. Recommended for production.
# Get a key at https://console.anthropic.com
# If this is set, it wins over GEMINI_API_KEY automatically.
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key-here


# -----------------------------------------------------------------------------
# Access control — API key (STRONGLY recommended for any deployment)
# -----------------------------------------------------------------------------
# Set ho to har /api endpoint is key ko `x-api-key` header mein maangega (warna
# 401). Frontend user se key ek dafa maangta hai aur localStorage mein rakh leta
# hai. UNSET chhodo to auth OFF rehta hai (local dev) — par production mein
# ISE ZAROOR SET KARO, warna koi bhi tumhare AI tokens (paisa) aur DB use kar
# sakta hai. Koi bhi lambi random string chalti hai.
# PAPER_MAKER_API_KEY=change-me-to-a-long-random-string

# CORS: comma-separated origins jo browser se /api call kar sakti hain. Frontend
# same-origin (`/`) se serve hota hai to ise set karne ki zaroorat aam taur par
# nahi. Unset = `*` (sab allowed). Production mein apni domain tak lock karo.
# PAPER_MAKER_ALLOWED_ORIGINS=https://paper.myschool.edu.pk


# -----------------------------------------------------------------------------
# Database location (optional)
# -----------------------------------------------------------------------------
# Absolute or relative path to the SQLite file. Defaults to `paper_maker.db`
# in the project root. On an ephemeral host (e.g. Railway) point this at a
# mounted persistent volume so data survives redeploys.
# DB_PATH=/data/paper_maker.db


# -----------------------------------------------------------------------------
# PDF export — LibreOffice binary (optional)
# -----------------------------------------------------------------------------
# Only needed for PDF export, and only if LibreOffice is installed somewhere
# non-standard. The app auto-detects the binary via: SOFFICE_PATH -> system
# PATH -> common install locations. Word (.docx) export needs no LibreOffice.
# SOFFICE_PATH=C:\Program Files\LibreOffice\program\soffice.exe


# -----------------------------------------------------------------------------
# Server port (optional)
# -----------------------------------------------------------------------------
# Not read by the app directly — used by the deploy start command
# (`uvicorn ... --port $PORT`). Railway injects this automatically. For local
# development pass `--port 8000` on the uvicorn command line instead.
# PORT=8000
